{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "scottprecisionhealth",
  "main": ".vercel/output/static/_worker.js", // Direct entry to the worker script
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".vercel/output/static",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
